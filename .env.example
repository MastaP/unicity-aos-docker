# Copy to `.env` and fill in. `.env` is gitignored вЂ” keep every credential
# here and nowhere else. Nothing secret belongs in the Dockerfile, the compose
# file, or the image.
#
#   cp .env.example .env && chmod 600 .env

# в”Ђв”Ђв”Ђ LLM provider (OpenAI-compatible) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Any OpenAI-compatible endpoint works.
#
# IMPORTANT: the base URL must NOT include the `/v1` suffix вЂ” the provider
# capsule appends `/v1/models` and `/v1/chat/completions` itself.
#
#   https://api.openai.com                    OpenAI
#   https://api.moonshot.ai                   Moonshot / Kimi
#   http://host.docker.internal:11434         local ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.4

# в”Ђв”Ђв”Ђ Telegram uplink (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Leave TELEGRAM_BOT_TOKEN empty to skip installing the Telegram capsule
# entirely. Get a token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user ids allowed to use the bot; ask
# @userinfobot for yours.
#
# WARNING: leaving this EMPTY lets ANY Telegram user drive your agent вЂ” with
# your provider credits and whatever tools the agent can reach. All Telegram
# users share one AOS principal, so this allowlist is the only isolation
# boundary. Set it.
TELEGRAM_ALLOWED_USER_IDS=

# в”Ђв”Ђв”Ђ Runtime state в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Host directory holding ALL runtime state: runtime keys, secrets, KV,
# sessions, the audit chain, installed capsules, and anything an agent builds
# with Forge. A bind mount, so it survives `docker compose down -v`.
# Must be owned by uid 1000 (the container's user).
AOS_DATA_DIR=./data

# в”Ђв”Ђв”Ђ Image build в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Git refs built into the image. `main` tracks tip; pin to a tag or commit for
# a reproducible build.
AOS_CE_REF=main
TELEGRAM_REF=main

# Set to 1 ONLY if you genuinely want a public bot. Without it, an empty
# TELEGRAM_ALLOWED_USER_IDS makes the container refuse to install the uplink.
TELEGRAM_ALLOW_ANY_USER=0

# в”Ђв”Ђв”Ђ Build target в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# `runtime` (default): slim production image, no compiler.
# `devtools`:          adds the Rust toolchain so `astrid capsule build` works
#                      inside the container. Needed if you want the agent (or
#                      yourself, via `docker compose exec`) to build capsules
#                      in place. Larger image; a compiler alongside agent-run
#                      code is extra attack surface, so it is opt-in.
AOS_IMAGE_TARGET=runtime
